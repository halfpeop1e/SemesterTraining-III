# Maven
target/
*.class
*.jar
*.war

# IDE
.idea/
*.iml
.vscode/
.project
.classpath
.settings/
.trae/
# Node
node_modules/
dist/
*.local

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local

# Large binary / raw data (must not be committed)
data/

# 后端资源中的小数据文件允许提交（客流CSV + 人口密度JSON）
!backend/src/main/resources/data/

# 大体积协议原文 xls/docx（团队决定是否留仓；若已跟踪请 git rm --cached）
*.xls
*.xlsx
*.docx

# Agent working memory（整目录忽略 + 不跟踪）
.workbuddy/

# 日志文件
*.log
backend.log
frontend.log

# 后端 classpath 临时文件（脚本自动生成）
backend/cp-argfile.txt

# Vite timestamp 缓存 / 构建产物
frontend-control-center/.vite/
frontend-control-center/dist/

# Agent scratch logs / temp artifacts (NOT to be committed)
backend/backend-changelog-*.md
backend/body.json
backend/**/body.json
文档/

.fake
frontend-control-center/test-results/

# 仓外辅助目录（保持在仓外即可，不纳入 git）
# .docs/ .docx/ .harness/ .history/ verify/ 均位于 git 仓库根之外